# APP_ENV で読み込む .env ファイルが決まる (デフォルト: local)
# APP_ENV=local       → .env.local (cognito-local, localstack, local postgres)
# APP_ENV=development → .env.development (AWS dev 環境)
# APP_ENV=production  → .env.production (AWS 本番環境)

DATABASE_URL=postgres://walking_dog:password@postgres:5432/walking_dog_dev
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT_URL=http://localstack:4566
DYNAMODB_ENDPOINT_URL=http://dynamodb-local:8000
DYNAMODB_TABLE_WALK_POINTS=WalkPoints
S3_BUCKET_DOG_PHOTOS=dog-photos
COGNITO_USER_POOL_ID=local_XXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXX
COGNITO_ENDPOINT_URL=http://cognito-local:9229
PORT=3000
# TEST_MODE=true  # JWT検証をスキップしてテスト用固定ユーザーを返す
